
config system
	option hostname 'RouterF5'
	option timezone '<+06>-6'
	option ttylogin '0'
	option log_size '64'
	option urandom_seed '512'
	option description 'Router for the 5th floor'
	option notes 'Provides access point, switch, VLAN capabilities'
	option zonename 'Asia/Dhaka'
	option log_proto 'udp'
	option conloglevel '5'
	option cronloglevel '5'

config timeserver 'ntp'
	list server '0.openwrt.pool.ntp.org'
	list server '1.openwrt.pool.ntp.org'
	list server '2.openwrt.pool.ntp.org'
	list server '3.openwrt.pool.ntp.org'

